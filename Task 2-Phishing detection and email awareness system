<!DOCTYPE html>
<html>
<head>
    <title>SmartShield Phishing Checker</title>
    <style>
        body { font-family: Arial; padding: 20px; }
        textarea { width: 100%; height: 150px; }
        button { padding: 10px; margin-top: 10px; }
        .result { margin-top: 20px; font-weight: bold; }
    </style>
</head>
<body>

<h2>SmartShield Email Risk Checker</h2>

<p>Paste email content below:</p>
<textarea id="emailInput"></textarea>

<br>
<button onclick="analyzeEmail()">Analyze Email</button>

<div class="result" id="result"></div>

<script>
function analyzeEmail() {
    let text = document.getElementById("emailInput").value.toLowerCase();
    let score = 0;

    if (text.includes("urgent")) score += 2;
    if (text.includes("click here")) score += 2;
    if (text.includes("verify your account")) score += 3;
    if (text.includes("bank")) score += 1;
    if (text.includes("password")) score += 3;

    let result = "";

    if (score >= 6) {
        result = "⚠️ PHISHING EMAIL";
    } else if (score >= 3) {
        result = "⚠️ SUSPICIOUS EMAIL";
    } else {
        result = "✅ SAFE EMAIL";
    }

    document.getElementById("result").innerText = result;
}
</script>

</body>
</html>
